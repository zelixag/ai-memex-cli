{
  "name": "ai-memex-cli",
  "version": "0.1.0",
  "description": "CLI for building and maintaining persistent LLM wikis",
  "type": "module",
  "bin": {
    "memex": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "cli",
    "knowledge-base",
    "wiki",
    "llm",
    "claude",
    "ai-agent",
    "memex",
    "persistent-memory"
  ],
  "author": "zelixag",
  "license": "MIT",
  "homepage": "https://github.com/zelixag/ai-memex-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zelixag/ai-memex-cli.git"
  },
  "bugs": {
    "url": "https://github.com/zelixag/ai-memex-cli/issues"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "cac": "^6.7.14",
    "chokidar": "^4.0.0",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
